{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Labalaba",
  "version": "1.2.10",
  "identifier": "com.rizquuula.labalaba",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../build"
  },
  "app": {
    "windows": [
      {
        "title": "Labalaba",
        "width": 800,
        "height": 600
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": ["binaries/labalaba-daemon"],
    "windows": {
      "nsis": {
        "installerHooks": "installer-hooks.nsh"
      }
    },
    "linux": {
      "deb": {
        "preRemoveScript": "deb/prerm.sh"
      }
    }
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDkwOEY1MEJDQzVCNzlGRkYKUldUL243ZkZ2RkNQa0R0R2hjbVIrYlRPMUtWS09NMko5SkxiQUdrYy9vaVRCTWNqWVozN2c5L1QK",
      "endpoints": [
        "https://github.com/rizquuula/Labalaba/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
